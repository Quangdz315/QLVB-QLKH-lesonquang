<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_chuc_vu_tree" model="ir.ui.view">
            <field name="name">chuc_vu.tree</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="phong_ban_id"/>
                    <field name="he_so_chuc_vu"/>
                    <field name="so_nhan_vien"/>
                    <field name="active" optional="hide"/>
                </tree>
            </field>
        </record>
        <record id="view_chuc_vu_form" model="ir.ui.view">
            <field name="name">chuc_vu.form</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <form string="Chức vụ">
                    <sheet>
                        <div class="oe_title">
                            <label for="ten_chuc_vu"/>
                            <h1><field name="ten_chuc_vu" placeholder="Tên chức vụ..."/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="ma_chuc_vu"/>
                                <field name="phong_ban_id"/>
                            </group>
                            <group>
                                <field name="he_so_chuc_vu"/>
                                <field name="so_nhan_vien" readonly="1"/>
                                <field name="active"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Nhân viên">
                                <field name="nhan_vien_ids" readonly="1">
                                    <tree>
                                        <field name="ma_dinh_danh"/>
                                        <field name="ho_ten"/>
                                        <field name="phong_ban_id"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Mô tả công việc">
                                <field name="mo_ta"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_chuc_vu_search" model="ir.ui.view">
            <field name="name">chuc_vu.search</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="phong_ban_id"/>
                    <filter name="inactive" string="Ngừng sử dụng" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_department" string="Phòng ban"
                                context="{'group_by': 'phong_ban_id'}"/>
                    </group>
                </search>
            </field>
        </record>
        <record id="action_chuc_vu" model="ir.actions.act_window">
            <field name="name">Chức vụ</field>
            <field name="res_model">chuc_vu</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_chuc_vu_search"/>
        </record>
    </data>
</odoo>
