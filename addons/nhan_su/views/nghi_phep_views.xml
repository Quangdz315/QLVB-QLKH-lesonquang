<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_nghi_phep_tree" model="ir.ui.view">
        <field name="name">nghi_phep.tree</field><field name="model">nghi_phep</field>
        <field name="arch" type="xml"><tree decoration-success="trang_thai == 'da_duyet'" decoration-danger="trang_thai == 'tu_choi'" decoration-muted="trang_thai in ('huy')">
            <field name="ma_don"/><field name="nhan_vien_id"/><field name="phong_ban_id"/>
            <field name="loai_nghi"/><field name="ngay_bat_dau"/><field name="ngay_ket_thuc"/>
            <field name="so_ngay" sum="Tổng ngày"/><field name="trang_thai" widget="badge"/>
        </tree></field>
    </record>
    <record id="view_nghi_phep_form" model="ir.ui.view">
        <field name="name">nghi_phep.form</field><field name="model">nghi_phep</field>
        <field name="arch" type="xml"><form string="Đơn nghỉ phép">
            <header>
                <button name="action_gui_duyet" string="Gửi duyệt" type="object" class="oe_highlight" attrs="{'invisible': [('trang_thai', '!=', 'nhap')]}"/>
                <button name="action_duyet" string="Duyệt" type="object" class="oe_highlight" attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                <button name="action_tu_choi" string="Từ chối" type="object" attrs="{'invisible': [('trang_thai', '!=', 'cho_duyet')]}"/>
                <button name="action_huy" string="Hủy" type="object" attrs="{'invisible': [('trang_thai', 'in', ('da_duyet','huy'))]}"/>
                <button name="action_dat_nhap" string="Đặt về nháp" type="object" attrs="{'invisible': [('trang_thai', 'not in', ('tu_choi','huy'))]}"/>
                <field name="trang_thai" widget="statusbar" statusbar_visible="nhap,cho_duyet,da_duyet"/>
            </header>
            <sheet>
                <div class="oe_title"><h1><field name="ma_don" readonly="1"/></h1></div>
                <group>
                    <group string="Nhân sự">
                        <field name="nhan_vien_id"/><field name="phong_ban_id" readonly="1"/><field name="chuc_vu_id" readonly="1"/>
                    </group>
                    <group string="Thời gian nghỉ">
                        <field name="loai_nghi"/><field name="ngay_bat_dau"/><field name="ngay_ket_thuc"/><field name="so_ngay" readonly="1"/>
                    </group>
                </group>
                <group><field name="ly_do"/><field name="ghi_chu_duyet"/></group>
                <group string="Thông tin duyệt"><field name="nguoi_duyet_id" readonly="1"/><field name="ngay_duyet" readonly="1"/></group>
            </sheet>
        </form></field>
    </record>
    <record id="view_nghi_phep_search" model="ir.ui.view">
        <field name="name">nghi_phep.search</field><field name="model">nghi_phep</field>
        <field name="arch" type="xml"><search>
            <field name="ma_don"/><field name="nhan_vien_id"/><field name="phong_ban_id"/><field name="loai_nghi"/><field name="trang_thai"/><field name="ngay_bat_dau"/>
            <filter name="cho_duyet" string="Chờ duyệt" domain="[('trang_thai','=','cho_duyet')]"/>
            <filter name="da_duyet" string="Đã duyệt" domain="[('trang_thai','=','da_duyet')]"/>
            <group expand="0" string="Nhóm theo">
                <filter name="group_nhan_vien" string="Nhân viên" context="{'group_by':'nhan_vien_id'}"/>
                <filter name="group_phong_ban" string="Phòng ban" context="{'group_by':'phong_ban_id'}"/>
                <filter name="group_loai" string="Loại nghỉ" context="{'group_by':'loai_nghi'}"/>
                <filter name="group_trang_thai" string="Trạng thái" context="{'group_by':'trang_thai'}"/>
            </group>
        </search></field>
    </record>
    <record id="action_nghi_phep" model="ir.actions.act_window">
        <field name="name">Nghỉ phép</field><field name="res_model">nghi_phep</field><field name="view_mode">tree,form</field><field name="search_view_id" ref="view_nghi_phep_search"/>
    </record>
</data></odoo>
