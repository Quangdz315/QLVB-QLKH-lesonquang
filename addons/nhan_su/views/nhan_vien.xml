<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_nhan_vien_form" model="ir.ui.view">
            <field name="name">nhan_vien.form</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <form string="Hồ sơ nhân viên">
                    <header>
                        <button name="action_thu_viec" type="object" string="Chuyển thử việc"
                                class="oe_highlight" attrs="{'invisible': [('trang_thai', 'not in', ['tam_nghi', 'da_nghi'])]}"/>
                        <button name="action_dang_lam" type="object" string="Xác nhận làm việc"
                                class="oe_highlight" attrs="{'invisible': [('trang_thai', 'not in', ['thu_viec', 'tam_nghi'])]}"/>
                        <button name="action_tam_nghi" type="object" string="Tạm nghỉ"
                                attrs="{'invisible': [('trang_thai', 'not in', ['thu_viec', 'dang_lam'])]}"/>
                        <button name="action_nghi_viec" type="object" string="Nghỉ việc"
                                attrs="{'invisible': [('trang_thai', 'not in', ['thu_viec', 'dang_lam', 'tam_nghi'])]}"/>
                        <field name="trang_thai" widget="statusbar"
                               statusbar_visible="thu_viec,dang_lam,tam_nghi,da_nghi"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_hop_dong" type="object"
                                    class="oe_stat_button" icon="fa-file-text-o">
                                <field name="so_hop_dong" widget="statinfo" string="Hợp đồng"/>
                            </button>
                        </div>
                        <widget name="web_ribbon" title="Đã nghỉ việc" bg_color="bg-danger"
                                attrs="{'invisible': [('trang_thai', '!=', 'da_nghi')]}"/>
                        <field name="image_1920" widget="image" class="oe_avatar"
                               options="{'preview_image': 'image_1920'}"/>
                        <div class="oe_title">
                            <label for="ho_ten" string="Họ và tên"/>
                            <h1><field name="ho_ten" placeholder="Nhập họ và tên..." required="1"/></h1>
                            <div class="o_row">
                                <field name="ma_dinh_danh" readonly="1"/>
                                <field name="active" invisible="1"/>
                            </div>
                        </div>

                        <group>
                            <group string="Vị trí công việc">
                                <field name="phong_ban_id"/>
                                <field name="chuc_vu_id"/>
                                <field name="quan_ly_id"/>
                                <field name="loai_nhan_vien"/>
                            </group>
                            <group string="Thông tin liên hệ nhanh">
                                <field name="email_cong_ty" widget="email"/>
                                <field name="so_dien_thoai"/>
                                <field name="ngay_vao_lam"/>
                                <field name="ngay_nghi_viec"
                                       attrs="{'invisible': [('trang_thai', '!=', 'da_nghi')]}"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Thông tin cá nhân">
                                <group>
                                    <group string="Thông tin cơ bản">
                                        <field name="ten_khac"/>
                                        <field name="gioi_tinh"/>
                                        <field name="ngay_sinh"/>
                                        <field name="tuoi" readonly="1"/>
                                        <field name="noi_sinh"/>
                                        <field name="que_quan"/>
                                    </group>
                                    <group string="Thông tin bổ sung">
                                        <field name="quoc_tich"/>
                                        <field name="dan_toc"/>
                                        <field name="ton_giao"/>
                                        <field name="tinh_trang_hon_nhan"/>
                                    </group>
                                </group>
                                <group string="Giấy tờ tùy thân">
                                    <field name="so_cccd"/>
                                    <field name="ngay_cap_cccd"/>
                                    <field name="noi_cap_cccd"/>
                                </group>
                            </page>

                            <page string="Liên hệ &amp; Địa chỉ">
                                <group>
                                    <group string="Liên hệ">
                                        <field name="email" widget="email"/>
                                        <field name="email_cong_ty" widget="email"/>
                                        <field name="so_dien_thoai"/>
                                    </group>
                                    <group string="Liên hệ khẩn cấp">
                                        <field name="nguoi_lien_he_khan_cap"/>
                                        <field name="quan_he_khan_cap"/>
                                        <field name="so_dien_thoai_khan_cap"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="dia_chi_thuong_tru"/>
                                    <field name="dia_chi_tam_tru"/>
                                </group>
                            </page>

                            <page string="Học vấn">
                                <group>
                                    <field name="trinh_do_hoc_van"/>
                                    <field name="chuyen_nganh"/>
                                    <field name="truong_dao_tao"/>
                                    <field name="nam_tot_nghiep"/>
                                </group>
                            </page>

                            <page string="Ngân hàng &amp; Bảo hiểm">
                                <group>
                                    <group string="Thông tin ngân hàng">
                                        <field name="so_tai_khoan"/>
                                        <field name="ten_ngan_hang"/>
                                        <field name="chi_nhanh_ngan_hang"/>
                                    </group>
                                    <group string="Thuế và bảo hiểm">
                                        <field name="ma_so_thue"/>
                                        <field name="so_bhxh"/>
                                        <field name="so_bhyt"/>
                                    </group>
                                </group>
                            </page>

                            <page string="Hợp đồng">
                                <field name="hop_dong_ids" context="{'default_nhan_vien_id': active_id}">
                                    <tree editable="bottom">
                                        <field name="ma_hop_dong" readonly="1"/>
                                        <field name="loai_hop_dong"/>
                                        <field name="ngay_bat_dau"/>
                                        <field name="ngay_ket_thuc"/>
                                        <field name="luong_co_ban"/>
                                        <field name="phu_cap"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Cấp dưới">
                                <field name="cap_duoi_ids" readonly="1">
                                    <tree>
                                        <field name="ma_dinh_danh"/>
                                        <field name="ho_ten"/>
                                        <field name="phong_ban_id"/>
                                        <field name="chuc_vu_id"/>
                                        <field name="trang_thai"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Ghi chú">
                                <field name="ghi_chu" placeholder="Ghi chú nội bộ về nhân viên..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_nhan_vien_tree" model="ir.ui.view">
            <field name="name">nhan_vien.tree</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <tree decoration-muted="trang_thai == 'da_nghi'"
                      decoration-warning="trang_thai == 'tam_nghi'"
                      decoration-info="trang_thai == 'thu_viec'">
                    <field name="ma_dinh_danh"/>
                    <field name="ho_ten"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <field name="so_dien_thoai" optional="show"/>
                    <field name="email_cong_ty" optional="show"/>
                    <field name="ngay_vao_lam" optional="hide"/>
                    <field name="loai_nhan_vien" optional="hide"/>
                    <field name="trang_thai" widget="badge"/>
                </tree>
            </field>
        </record>

        <record id="view_nhan_vien_kanban" model="ir.ui.view">
            <field name="name">nhan_vien.kanban</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <kanban default_group_by="phong_ban_id" class="o_kanban_small_column">
                    <field name="id"/>
                    <field name="image_1920"/>
                    <field name="ho_ten"/>
                    <field name="ma_dinh_danh"/>
                    <field name="chuc_vu_id"/>
                    <field name="phong_ban_id"/>
                    <field name="email_cong_ty"/>
                    <field name="so_dien_thoai"/>
                    <field name="trang_thai"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click o_kanban_record">
                                <div class="o_kanban_image">
                                    <img t-att-src="kanban_image('nhan_vien', 'image_1920', record.id.raw_value)"
                                         alt="Nhân viên"/>
                                </div>
                                <div class="oe_kanban_details">
                                    <strong class="o_kanban_record_title">
                                        <field name="ho_ten"/>
                                    </strong>
                                    <div><field name="ma_dinh_danh"/></div>
                                    <div><field name="chuc_vu_id"/></div>
                                    <div t-if="record.email_cong_ty.raw_value">
                                        <i class="fa fa-envelope-o" title="Email"/> <field name="email_cong_ty"/>
                                    </div>
                                    <div t-if="record.so_dien_thoai.raw_value">
                                        <i class="fa fa-phone" title="Điện thoại"/> <field name="so_dien_thoai"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="nhan_vien_search" model="ir.ui.view">
            <field name="name">nhan_vien.search</field>
            <field name="model">nhan_vien</field>
            <field name="arch" type="xml">
                <search string="Tìm kiếm nhân viên">
                    <field name="ho_ten"/>
                    <field name="ma_dinh_danh"/>
                    <field name="email"/>
                    <field name="email_cong_ty"/>
                    <field name="so_dien_thoai"/>
                    <field name="phong_ban_id"/>
                    <field name="chuc_vu_id"/>
                    <field name="trang_thai"/>
                    <field name="loai_nhan_vien"/>
                    <filter name="dang_lam" string="Đang làm việc"
                            domain="[('trang_thai', '=', 'dang_lam')]"/>
                    <filter name="thu_viec" string="Thử việc"
                            domain="[('trang_thai', '=', 'thu_viec')]"/>
                    <filter name="tam_nghi" string="Tạm nghỉ"
                            domain="[('trang_thai', '=', 'tam_nghi')]"/>
                    <filter name="da_nghi" string="Đã nghỉ việc"
                            domain="[('trang_thai', '=', 'da_nghi')]"/>
                    <separator/>
                    <filter name="inactive" string="Đã lưu trữ"
                            domain="[('active', '=', False)]"/>
                    <group expand="0" string="Nhóm theo">
                        <filter name="group_phong_ban" string="Phòng ban"
                                context="{'group_by': 'phong_ban_id'}"/>
                        <filter name="group_chuc_vu" string="Chức vụ"
                                context="{'group_by': 'chuc_vu_id'}"/>
                        <filter name="group_trang_thai" string="Trạng thái"
                                context="{'group_by': 'trang_thai'}"/>
                        <filter name="group_loai_nhan_vien" string="Loại nhân viên"
                                context="{'group_by': 'loai_nhan_vien'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="action_nhan_vien" model="ir.actions.act_window">
            <field name="name">Nhân viên</field>
            <field name="res_model">nhan_vien</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="nhan_vien_search"/>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Tạo hồ sơ nhân viên đầu tiên</p>
                <p>Quản lý thông tin cá nhân, công việc, hợp đồng và trạng thái nhân sự.</p>
            </field>
        </record>
    </data>
</odoo>
