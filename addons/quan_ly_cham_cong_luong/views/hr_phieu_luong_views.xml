<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_hr_phieu_luong_form" model="ir.ui.view">
        <field name="name">hr_phieu_luong.form</field><field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml"><form string="Phiếu lương tháng"><sheet>
            <group>
                <group string="Kỳ lương">
                    <field name="nhan_vien_id"/><field name="phong_ban_id" readonly="1"/>
                    <field name="chuc_vu_id" readonly="1"/><field name="thang"/><field name="nam"/>
                </group>
                <group string="Nguồn thu nhập">
                    <field name="hop_dong_id" readonly="1"/>
                    <field name="nguon_luong" readonly="1"/>
                    <field name="luong_co_ban" readonly="1"/>
                    <field name="phu_cap" readonly="1"/>
                </group>
            </group>
            <group string="Tổng hợp trong tháng">
                <field name="so_ngay_di_lam" readonly="1"/>
                <field name="so_gio_tang_ca" readonly="1"/>
                <field name="tong_khen_thuong" readonly="1"/>
                <field name="tong_ky_luat" readonly="1"/>
                <field name="thuc_linh" readonly="1"/>
            </group>
            <group string="Ghi chú"><field name="ghi_chu"/></group>
        </sheet></form></field>
    </record>
    <record id="view_hr_phieu_luong_tree" model="ir.ui.view">
        <field name="name">hr_phieu_luong.tree</field><field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml"><tree>
            <field name="nam"/><field name="thang"/><field name="nhan_vien_id"/>
            <field name="phong_ban_id"/><field name="hop_dong_id" optional="hide"/>
            <field name="so_ngay_di_lam"/><field name="so_gio_tang_ca" optional="hide"/>
            <field name="luong_co_ban"/><field name="phu_cap"/>
            <field name="tong_khen_thuong"/><field name="tong_ky_luat"/>
            <field name="thuc_linh" sum="Tổng thực lĩnh"/>
        </tree></field>
    </record>
    <record id="view_hr_phieu_luong_search" model="ir.ui.view">
        <field name="name">hr_phieu_luong.search</field><field name="model">hr_phieu_luong</field>
        <field name="arch" type="xml"><search>
            <field name="nhan_vien_id"/><field name="phong_ban_id"/><field name="thang"/><field name="nam"/>
            <group expand="0" string="Nhóm theo">
                <filter name="group_nhan_vien" string="Nhân viên" context="{'group_by':'nhan_vien_id'}"/>
                <filter name="group_phong_ban" string="Phòng ban" context="{'group_by':'phong_ban_id'}"/>
                <filter name="group_nam" string="Năm" context="{'group_by':'nam'}"/>
                <filter name="group_thang" string="Tháng" context="{'group_by':'thang'}"/>
            </group>
        </search></field>
    </record>
    <record id="action_hr_phieu_luong" model="ir.actions.act_window">
        <field name="name">Phiếu lương tháng</field><field name="res_model">hr_phieu_luong</field>
        <field name="view_mode">tree,form</field><field name="search_view_id" ref="view_hr_phieu_luong_search"/>
    </record>
</data></odoo>
