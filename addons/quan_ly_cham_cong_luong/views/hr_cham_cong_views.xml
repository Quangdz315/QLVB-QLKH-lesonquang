<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_hr_cham_cong_form" model="ir.ui.view">
        <field name="name">hr_cham_cong.form</field><field name="model">hr_cham_cong</field>
        <field name="arch" type="xml"><form string="Chấm công hằng ngày"><sheet>
            <group>
                <group string="Nhân sự">
                    <field name="nhan_vien_id"/><field name="phong_ban_id" readonly="1"/>
                    <field name="chuc_vu_id" readonly="1"/>
                </group>
                <group string="Ngày công">
                    <field name="ngay_cham_cong"/><field name="trang_thai"/>
                    <field name="so_gio_tang_ca"/><field name="nguoi_xac_nhan"/>
                </group>
            </group>
        </sheet></form></field>
    </record>
    <record id="view_hr_cham_cong_tree" model="ir.ui.view">
        <field name="name">hr_cham_cong.tree</field><field name="model">hr_cham_cong</field>
        <field name="arch" type="xml"><tree>
            <field name="ngay_cham_cong"/><field name="nhan_vien_id"/>
            <field name="phong_ban_id"/><field name="chuc_vu_id" optional="hide"/>
            <field name="trang_thai" widget="badge"/><field name="so_gio_tang_ca"/>
            <field name="nguoi_xac_nhan" optional="hide"/>
        </tree></field>
    </record>
    <record id="view_hr_cham_cong_search" model="ir.ui.view">
        <field name="name">hr_cham_cong.search</field><field name="model">hr_cham_cong</field>
        <field name="arch" type="xml"><search>
            <field name="nhan_vien_id"/><field name="phong_ban_id"/><field name="ngay_cham_cong"/>
            <filter name="di_lam" string="Đi làm" domain="[('trang_thai','=','di_lam')]"/>
            <filter name="nua_ngay" string="Nửa ngày" domain="[('trang_thai','=','nua_ngay')]"/>
            <group expand="0" string="Nhóm theo">
                <filter name="group_nhan_vien" string="Nhân viên" context="{'group_by':'nhan_vien_id'}"/>
                <filter name="group_phong_ban" string="Phòng ban" context="{'group_by':'phong_ban_id'}"/>
                <filter name="group_ngay" string="Ngày" context="{'group_by':'ngay_cham_cong'}"/>
            </group>
        </search></field>
    </record>
    <record id="action_hr_cham_cong" model="ir.actions.act_window">
        <field name="name">Chấm công hằng ngày</field><field name="res_model">hr_cham_cong</field>
        <field name="view_mode">tree,form</field><field name="search_view_id" ref="view_hr_cham_cong_search"/>
    </record>
</data></odoo>
