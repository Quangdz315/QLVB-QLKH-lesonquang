<?xml version="1.0" encoding="utf-8"?>
<odoo><data>
    <record id="view_nhan_vien_form_inherit_cham_cong_luong" model="ir.ui.view">
        <field name="name">nhan_vien.form.cham_cong_luong</field>
        <field name="model">nhan_vien</field>
        <field name="inherit_id" ref="nhan_su.view_nhan_vien_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_cham_cong" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                    <field name="so_ban_cham_cong" widget="statinfo" string="Chấm công"/>
                </button>
                <button name="action_view_khen_thuong_ky_luat" type="object" class="oe_stat_button" icon="fa-trophy">
                    <field name="so_quyet_dinh" widget="statinfo" string="Thưởng/Phạt"/>
                </button>
                <button name="action_view_phieu_luong" type="object" class="oe_stat_button" icon="fa-money">
                    <field name="so_phieu_luong" widget="statinfo" string="Phiếu lương"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Chấm công &amp; Lương">
                    <group string="Cấu hình lương">
                        <field name="cau_hinh_luong_ids" context="{'default_nhan_vien_id': active_id}">
                            <tree editable="bottom">
                                <field name="nhan_vien_id" invisible="1"/>
                                <field name="hop_dong_id"/><field name="luong_co_ban"/>
                                <field name="phu_cap_an_trua"/><field name="phu_cap_trach_nhiem"/>
                            </tree>
                        </field>
                    </group>
                    <group string="Phiếu lương gần đây">
                        <field name="phieu_luong_ids" readonly="1">
                            <tree>
                                <field name="nam"/><field name="thang"/><field name="so_ngay_di_lam"/>
                                <field name="luong_co_ban"/><field name="tong_khen_thuong"/>
                                <field name="tong_ky_luat"/><field name="thuc_linh"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hop_dong_form_inherit_dong_bo_luong" model="ir.ui.view">
        <field name="name">hop_dong_lao_dong.form.dong_bo_luong</field>
        <field name="model">hop_dong_lao_dong</field>
        <field name="inherit_id" ref="nhan_su.view_hop_dong_lao_dong_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='trang_thai']" position="before">
                <button name="action_dong_bo_cau_hinh_luong" type="object"
                        string="Đồng bộ lương" class="oe_highlight"
                        attrs="{'invisible':[('trang_thai','!=','hieu_luc')]}"/>
            </xpath>
        </field>
    </record>
</data></odoo>
