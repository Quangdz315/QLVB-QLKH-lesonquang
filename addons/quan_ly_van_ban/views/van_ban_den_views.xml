<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_van_ban_den_form" model="ir.ui.view">
        <field name="name">van.ban.den.form</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <form string="Văn bản đến">
                <sheet>
                    <group>
                        <group string="Thông tin văn bản">
                            <field name="so_van_ban_den"/>
                            <field name="so_hieu_van_ban"/>
                            <field name="ten_van_ban"/>
                            <field name="loai_van_ban_id"/>
                            <field name="ngay_den"/>
                            <field name="nhom_van_ban"/>
                        </group>
                        <group string="Nguồn gửi">
                            <field name="co_quan_doi_tac_gui_id" attrs="{'invisible': [('nhom_van_ban', '!=', 'co_quan_doi_tac')]}"/>
                            <field name="nhan_vien_gui_id" attrs="{'invisible': [('nhom_van_ban', '!=', 'nhan_vien')]}"/>
                            <field name="phong_ban_gui_id" attrs="{'invisible': [('nhom_van_ban', '!=', 'phong_ban')]}"/>
                            <field name="noi_gui" placeholder="Ghi chú nơi gửi khác nếu có..."/>
                            <field name="nguon_gui_tong_hop" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tiếp nhận &amp; xử lý">
                        <field name="don_vi_nhan"/>
                        <field name="nhan_vien_xu_ly_id"/>
                        <field name="nhan_vien_nhan_ids" widget="many2many_tags"/>
                        <field name="phong_ban_nhan_ids" widget="many2many_tags"/>
                        <field name="nguoi_nhan" placeholder="Ghi chú người nhận khác nếu có..."/>
                        <field name="nguoi_nhan_tong_hop" readonly="1"/>
                    </group>
                    <group string="Ghi chú">
                        <field name="ghi_chu"/>
                    </group>
                    <group string="AI hỗ trợ xử lý văn bản">
                        <field name="noi_dung_ai" placeholder="Nhập hoặc dán nội dung chính của văn bản để AI tóm tắt, phân loại..."/>
                        <field name="ai_chay_ngay"/>
                        <field name="ai_nguon_phan_tich" readonly="1" force_save="1"/>
                        <field name="ai_ket_qua_nhanh" readonly="1" force_save="1"/>
                        <field name="ai_can_xu_ly_gap" readonly="1" force_save="1"/>
                        <field name="ai_tom_tat" readonly="1" force_save="1"/>
                        <field name="ai_goi_y" readonly="1" force_save="1"/>
                        <field name="ai_hanh_dong_de_xuat" readonly="1" force_save="1"/>
                        <field name="ai_muc_do_uu_tien" readonly="1" force_save="1"/>
                        <field name="ai_da_phan_tich_luc" readonly="1" force_save="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_van_ban_den_tree" model="ir.ui.view">
        <field name="name">van.ban.den.tree</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <tree decoration-danger="ai_muc_do_uu_tien == 'cao'" decoration-warning="ai_muc_do_uu_tien == 'trung_binh'">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="nhom_van_ban"/>
                <field name="nguon_gui_tong_hop"/>
                <field name="nguoi_nhan_tong_hop"/>
                <field name="ai_muc_do_uu_tien" invisible="1"/>
                <field name="ai_ket_qua_nhanh" string="AI đề xuất"/>
                <field name="loai_van_ban_id"/>
                <field name="ngay_den"/>
            </tree>
        </field>
    </record>

    <record id="view_van_ban_den_search" model="ir.ui.view">
        <field name="name">van.ban.den.search</field>
        <field name="model">van_ban_den</field>
        <field name="arch" type="xml">
            <search string="Tìm văn bản đến">
                <field name="so_van_ban_den"/>
                <field name="so_hieu_van_ban"/>
                <field name="ten_van_ban"/>
                <field name="nhom_van_ban"/>
                <field name="loai_van_ban_id"/>
                <filter name="tu_co_quan_doi_tac" string="Từ cơ quan/đối tác" domain="[('nhom_van_ban','=','co_quan_doi_tac')]"/>
                <filter name="tu_nhan_vien" string="Từ nhân viên" domain="[('nhom_van_ban','=','nhan_vien')]"/>
                <filter name="tu_phong_ban" string="Từ phòng ban" domain="[('nhom_van_ban','=','phong_ban')]"/>
                <filter name="noi_bo" string="Nội bộ" domain="[('nhom_van_ban','=','noi_bo')]"/>
                <filter name="chung" string="Văn bản chung" domain="[('nhom_van_ban','=','chung')]"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_nhom" string="Nhóm văn bản" context="{'group_by': 'nhom_van_ban'}"/>
                    <filter name="group_loai" string="Loại văn bản" context="{'group_by': 'loai_van_ban_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_van_ban_den" model="ir.actions.act_window">
        <field name="name">Văn bản đến</field>
        <field name="res_model">van_ban_den</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_van_ban_den_search"/>
    </record>
</odoo>
