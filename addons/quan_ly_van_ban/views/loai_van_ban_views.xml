<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- TREE VIEW -->
    <record id="view_loai_van_ban_tree" model="ir.ui.view">
        <field name="name">loai.van.ban.tree</field>
        <field name="model">loai_van_ban</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_loai_van_ban_form" model="ir.ui.view">
        <field name="name">loai.van.ban.form</field>
        <field name="model">loai_van_ban</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
